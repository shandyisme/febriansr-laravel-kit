APP_NAME="Febrian Kit"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Default stack: MySQL/MariaDB. For a zero-config local demo, set DB_CONNECTION=sqlite.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=febrian_kit
DB_USERNAME=febrian_kit
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- Febrian Laravel Kit -------------------------------------------------
# Branding (see config/brand.php). Leave blank to use defaults (Febrian orange).
BRAND_LOGO_TEXT="${APP_NAME}"
# BRAND_LOGO_PATH=images/logo.svg
BRAND_FAVICON=/favicon.ico
BRAND_PRIMARY_COLOR=#ff6d01
BRAND_SECONDARY_COLOR=#0284c7
BRAND_ACCENT_COLOR=#06b6d4

# Auth
AUTH_REGISTRATION_ENABLED=false

# WhatsApp AI (Phase 3 — Febrian WA AI API)
WA_PROVIDER=wa_ai
WA_AI_BASE_URL=
WA_AI_API_KEY=
WA_AI_SEND_PATH=/api/send
